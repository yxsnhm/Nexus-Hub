# Nexus Hub 环境变量模板
# 复制此文件为 .env 并填入你的真实 API Key

# DeepSeek API
DEEPSEEK_API_KEY=sk-你的DeepSeek密钥

# 千问（阿里云）API
QWEN_API_KEY=sk-你的千问密钥

# 扣子（Coze）API
COZE_API_KEY=你的扣子密钥
COZE_BOT_ID=你的扣子Bot ID

# Claude API（可选）
CLAUDE_API_KEY=sk-你的Claude密钥

# Gemini API（可选）
GEMINI_API_KEY=你的Gemini密钥

# Llama API（可选）
LLAMA_API_KEY=你的Llama密钥

# Mistral API（可选）
MISTRAL_API_KEY=你的Mistral密钥

# 中国区 API（可选）
CHINAZ_API_KEY=sk-你的中国区密钥

# 论坛签名密钥（自定义随机字符串）
NEXUS_SECRET_KEY=请自定义一个复杂的随机字符串
